{
  "manifest_version": 3,
  "name": "Wardrobe Planner",
  "version": "1.0",
  "description": "Sauvegarder des articles dans votre planificateur de garde-robe.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_icon": "icon48.png",
    "default_title": "Sauvegarder l'article"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
